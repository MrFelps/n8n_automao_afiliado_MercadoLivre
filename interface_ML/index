<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Painel de Disparos - Mercado Livre</title>
  <style>
    :root {
      --ml-yellow: #FFE600;
      --ml-blue: #3483FA;
      --ml-blue-hover: #2968c8;
      --ml-dark: #333333;
      --ml-gray-light: #F5F5F5;
      --ml-gray-medium: #EBEBEB;
      --ml-gray-text: #666666;
      --ml-white: #FFFFFF;
      --ml-shadow: 0 1px 2px 0 rgba(0,0,0,.15);
      --font-family: 'Proxima Nova', -apple-system, 'Helvetica Neue', Helvetica, Roboto, Arial, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body { background-color: var(--ml-gray-light); font-family: var(--font-family); color: var(--ml-dark); -webkit-font-smoothing: antialiased; }
    .header { background-color: var(--ml-yellow); padding: 15px 30px; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--ml-shadow); position: sticky; top: 0; z-index: 10; }
    .header h1 { font-size: 22px; font-weight: 600; color: var(--ml-dark); }
    .webhook-config { display: flex; align-items: center; gap: 8px; }
    .webhook-config input { width: 420px; padding: 6px 12px; border: 2px solid rgba(0,0,0,0.2); border-radius: 4px; font-size: 12px; font-family: monospace; background: rgba(255,255,255,0.8); }
    .webhook-config input:focus { outline: none; border-color: rgba(0,0,0,0.5); background: white; }
    .webhook-label { font-size: 12px; font-weight: 700; color: var(--ml-dark); white-space: nowrap; }

    .container { max-width: 1200px; margin: 30px auto; padding: 0 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
    .card { background: var(--ml-white); border-radius: 6px; box-shadow: var(--ml-shadow); padding: 24px; display: flex; flex-direction: column; height: fit-content; }
    .card h2 { font-size: 18px; font-weight: 600; margin-bottom: 20px; color: var(--ml-dark); border-bottom: 1px solid var(--ml-gray-medium); padding-bottom: 12px; }

    .input-group { display: flex; flex-direction: column; gap: 12px; }
    textarea { width: 100%; height: 200px; padding: 14px; border: 1px solid #ccc; border-radius: 4px; font-family: monospace; font-size: 14px; resize: vertical; transition: border-color 0.2s; }
    textarea:focus { outline: none; border-color: var(--ml-blue); }

    .btn { padding: 0 24px; height: 48px; border: none; border-radius: 4px; font-size: 16px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: background-color 0.2s, transform 0.1s; }
    .btn:active { transform: scale(0.98); }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .btn-primary { background-color: var(--ml-blue); color: var(--ml-white); }
    .btn-primary:hover:not(:disabled) { background-color: var(--ml-blue-hover); }
    .btn-yellow { background-color: var(--ml-yellow); color: var(--ml-dark); }
    .btn-yellow:hover:not(:disabled) { background-color: #f0d800; }
    .btn-danger { background-color: #FA0000; color: white; }
    .btn-danger:hover:not(:disabled) { background-color: #d10000; }

    .controls { display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px; }
    .control-group { display: flex; flex-direction: column; gap: 8px; }
    .control-group label { font-size: 14px; font-weight: 600; color: var(--ml-dark); }
    .options-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .option-btn { background: var(--ml-gray-light); border: 1px solid var(--ml-gray-medium); padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; color: var(--ml-gray-text); cursor: pointer; transition: all 0.2s; }
    .option-btn.selected { background: var(--ml-yellow); border-color: var(--ml-yellow); color: var(--ml-dark); }

    .timer-panel { display: none; background-color: var(--ml-dark); color: white; padding: 15px 20px; border-radius: 6px; justify-content: space-around; align-items: center; margin-bottom: 20px; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); }
    .timer-box { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .timer-label { font-size: 12px; color: #aaaaaa; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; }
    .timer-value { font-size: 26px; font-weight: bold; font-family: monospace; color: var(--ml-yellow); }

    .actions { display: flex; gap: 12px; margin-top: 8px; }
    .actions .btn { flex: 1; }
    .status-panel { font-size: 14px; text-align: center; margin-top: 10px; font-weight: bold; color: var(--ml-blue); min-height: 20px; }

    .queue-header { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; padding-top: 20px; border-top: 1px solid var(--ml-gray-medium); margin-bottom: 12px; }
    .queue-header h3 { font-size: 16px; font-weight: 600; }

    .queue-list { display: flex; flex-direction: column; gap: 8px; max-height: 400px; overflow-y: auto; padding-right: 5px; }
    .queue-list::-webkit-scrollbar { width: 6px; }
    .queue-list::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
    .queue-list::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }

    .queue-item { display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--ml-gray-medium); border-radius: 4px; background: #fff; }
    .item-info { display: flex; flex-direction: column; gap: 4px; overflow: hidden; margin-right: 10px; flex: 1; }
    .item-url { font-size: 13px; color: var(--ml-dark); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: monospace; }
    
    @media (max-width: 900px) { .container { grid-template-columns: 1fr; } .webhook-config input { width: 220px; } }
  </style>
</head>
<body>

  <header class="header">
    <h1>Estratégia de Disparos - ML</h1>
    <div class="webhook-config">
      <span class="webhook-label">URL do n8n:</span>
      <!-- VALOR MASCARADO AQUI PARA O GITHUB -->
      <input type="text" id="webhookUrl" placeholder="https://0000000000.ngrok-free.dev/webhook/conta-gotas-ml" value="https://0000000000.ngrok-free.dev/webhook/conta-gotas-ml" />
    </div>
  </header>

  <div class="container">
    <div class="card">
      <h2>1. Adicionar Links à Fila</h2>
      <div class="input-group">
        <textarea id="linksInput" placeholder="Cole os links aqui..."></textarea>
        <button id="addBtn" class="btn btn-primary" onclick="adicionarLinks()">Enviar para a Planilha</button>
      </div>
    </div>

    <div class="card" id="queuePanel">
      <h2>2. Estratégia de Envio</h2>
      
      <!-- Cronômetros Visuais -->
      <div class="timer-panel" id="timerPanel">
        <div class="timer-box">
          <span class="timer-label">Próximo Lote Em:</span>
          <span class="timer-value" id="timerLote">--:--:--</span>
        </div>
        <div class="timer-box">
          <span class="timer-label">Próxima Postagem Em:</span>
          <span class="timer-value" id="timerPost">--:--:--</span>
        </div>
      </div>

      <div class="controls">
        <div class="control-group">
          <label>Frequência (Turnos):</label>
          <div class="options-row" id="turnoOptions">
            <button class="option-btn selected" data-val="imediato">Imediato (Contínuo)</button>
            <button class="option-btn" data-val="mtn">Manhã (10h), Tarde (14h) e Noite (19h)</button>
            <button class="option-btn" data-val="1h">A cada 1 hora</button>
          </div>
        </div>

        <div class="control-group">
          <label>Posts por Turno (Tamanho do Lote):</label>
          <div class="options-row" id="loteOptions">
            <button class="option-btn selected" data-val="1">1 post</button>
            <button class="option-btn" data-val="3">3 posts</button>
            <button class="option-btn" data-val="5">5 posts</button>
          </div>
        </div>

        <div class="control-group">
          <label>Intervalo (entre os posts do lote):</label>
          <div class="options-row" id="intervaloOptions">
            <button class="option-btn selected" data-val="10">10 seg</button>
            <button class="option-btn" data-val="30">30 seg</button>
            <button class="option-btn" data-val="60">1 min</button>
            <button class="option-btn" data-val="300">5 min</button>
          </div>
        </div>

        <div class="actions">
          <button id="startBtn" class="btn btn-yellow" onclick="iniciarEnvio()">Ativar Robô</button>
          <button id="cancelBtn" class="btn btn-danger" onclick="cancelarEnvio()" disabled>Desligar Robô</button>
        </div>

        <div class="status-panel" id="statusEnvioTexto">Pronto para configurar.</div>
      </div>

      <div class="queue-header">
        <h3>Links Aguardando Leitura (<span id="queueCount">0</span>)</h3>
      </div>
      <div class="queue-list" id="queueList"></div>
    </div>
  </div>

  <script>
    let fila = [];
    let confTurno = 'imediato';
    let confTamanho = 1;
    let confIntervalo = 10;

    // Variáveis do Cronômetro Visual
    let simulationInterval = null;
    let isActive = false;
    let nextLoteTimestamp = 0;
    let nextPostTimestamp = 0;
    let postsLeft = 0;

    window.onload = function () {
      setupBtns('turnoOptions', v => { confTurno = v; });
      setupBtns('loteOptions', v => { confTamanho = parseInt(v); });
      setupBtns('intervaloOptions', v => { confIntervalo = parseInt(v); });
      
      sincronizarComPlanilha();
      recuperarStatus(); // Pergunta ao servidor se o robô já está ligado
    };

    function setupBtns(id, cb) {
      const btns = document.getElementById(id).querySelectorAll('.option-btn');
      btns.forEach(b => b.addEventListener('click', function () {
        if(isActive) return; // Bloqueia botões enquanto estiver rodando
        btns.forEach(x => x.classList.remove('selected'));
        this.classList.add('selected');
        cb(this.dataset.val);
      }));
    }

    function runGoogleScript(funcName, ...args) {
      return new Promise((resolve, reject) => {
        google.script.run.withSuccessHandler(resolve).withFailureHandler(reject)[funcName](...args);
      });
    }

    // Resgata a memória da página se fechou e abriu de novo
    async function recuperarStatus() {
      try {
        const status = await runGoogleScript('verificarStatusRobo');
        if (status.ativo) {
          confTurno = status.turno;
          confTamanho = status.tamanho;
          confIntervalo = status.intervalo;

          document.querySelectorAll('#turnoOptions .option-btn').forEach(b => {
            b.classList.remove('selected');
            if (b.dataset.val === confTurno) b.classList.add('selected');
          });
          document.querySelectorAll('#loteOptions .option-btn').forEach(b => {
            b.classList.remove('selected');
            if (parseInt(b.dataset.val) === confTamanho) b.classList.add('selected');
          });
          document.querySelectorAll('#intervaloOptions .option-btn').forEach(b => {
            b.classList.remove('selected');
            if (parseInt(b.dataset.val) === confIntervalo) b.classList.add('selected');
          });

          document.getElementById('startBtn').disabled = true;
          document.getElementById('cancelBtn').disabled = false;
          document.getElementById('statusEnvioTexto').innerHTML = '✅ <span style="color: green">Robô Ativado! (Recuperado)</span>';

          isActive = true;
          document.getElementById('timerPanel').style.display = 'flex';
          postsLeft = 0; 
          nextLoteTimestamp = calcularProximoTurnoBg();
          if(simulationInterval) clearInterval(simulationInterval);
          simulationInterval = setInterval(updateTimers, 1000);
        }
      } catch (e) {
        console.error("Erro ao verificar status", e);
      }
    }

    async function sincronizarComPlanilha() {
      document.getElementById('statusEnvioTexto').innerText = '🔄 Lendo banco de dados...';
      try {
        const urlsPendentes = await runGoogleScript('carregarPendentesPlanilha');
        fila = urlsPendentes;
        if (!isActive) {
            document.getElementById('statusEnvioTexto').innerHTML = fila.length === 0 ? '⚠️ Fila limpa. Adicione novos links.' : '✅ <span style="color: green">Lidos da planilha.</span>';
        }
        renderizar();
      } catch(e) {
        document.getElementById('statusEnvioTexto').innerText = '❌ Erro de conexão com a planilha.';
      }
    }

    async function adicionarLinks() {
      const ta = document.getElementById('linksInput');
      const validos = ta.value.split(/\r?\n/).map(l => l.trim()).filter(l => l.includes('mercadolivre.com') || l.includes('mercadolibre.com'));
      if (validos.length === 0) return alert('Nenhum link válido.');
      
      document.getElementById('addBtn').disabled = true;
      document.getElementById('addBtn').innerText = "Salvando...";

      try {
        await runGoogleScript('adicionarLinksPlanilha', validos);
        ta.value = ''; 
        await sincronizarComPlanilha(); 
      } catch(e) {
        alert("Erro ao salvar no banco.");
      } finally {
        document.getElementById('addBtn').disabled = false;
        document.getElementById('addBtn').innerText = "Enviar para a Planilha";
      }
    }

    function renderizar() {
      const container = document.getElementById('queueList');
      document.getElementById('queueCount').innerText = fila.length;
      if (fila.length === 0) { container.innerHTML = '<div style="padding:15px;color:#666;text-align:center;font-size:14px;">A fila está vazia.</div>'; return; }
      
      container.innerHTML = '';
      fila.forEach((url, index) => {
        const div = document.createElement('div');
        div.className = 'queue-item';
        div.innerHTML = `<div class="item-info"><span class="item-url">${(index + 1)}. ${url.substring(0, 52) + '...'}</span></div>`;
        container.appendChild(div);
      });
    }

    // --- LÓGICA DE SIMULAÇÃO DOS CRONÔMETROS ---
    function formatTime(s) {
       if(s <= 0) return "00:00:00";
       let h = Math.floor(s / 3600);
       let m = Math.floor((s % 3600) / 60);
       let sec = s % 60;
       return `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${sec.toString().padStart(2,'0')}`;
    }

    function calcularProximoTurnoBg() {
      let now = new Date();
      if (confTurno === 'imediato') {
          return now.getTime() + 60000; 
      } else if (confTurno === '1h') {
          return now.getTime() + 3600000; 
      } else if (confTurno === 'mtn') {
          let target = new Date();
          let h = now.getHours();
          if (h < 10) target.setHours(10,0,0,0);
          else if (h < 14) target.setHours(14,0,0,0);
          else if (h < 19) target.setHours(19,0,0,0);
          else { target.setDate(target.getDate() + 1); target.setHours(10,0,0,0); }
          return target.getTime();
      }
    }

    function updateTimers() {
       if (!isActive) return;
       let now = Date.now();

       if (postsLeft > 0) {
          document.getElementById('timerLote').innerText = "Rodando...";
          if (now >= nextPostTimestamp) {
             postsLeft--;
             if (postsLeft > 0) {
                nextPostTimestamp = now + (confIntervalo * 1000);
             } else {
                nextLoteTimestamp = calcularProximoTurnoBg();
             }
          } else {
             let diff = Math.ceil((nextPostTimestamp - now)/1000);
             document.getElementById('timerPost').innerText = formatTime(diff);
          }
       } else {
          document.getElementById('timerPost').innerText = "--:--:--";
          if (now >= nextLoteTimestamp) {
             postsLeft = confTamanho;
             nextPostTimestamp = Date.now(); 
          } else {
             let diff = Math.ceil((nextLoteTimestamp - now)/1000);
             document.getElementById('timerLote').innerText = formatTime(diff);
          }
       }
    }

    async function iniciarEnvio() {
      let webhook = document.getElementById('webhookUrl').value.trim();
      if (!webhook) return alert('Insira a URL do n8n.');

      document.getElementById('startBtn').disabled = true;
      document.getElementById('cancelBtn').disabled = false;
      document.getElementById('statusEnvioTexto').innerText = '⏳ Ativando robô...';

      try {
        await runGoogleScript('configurarTriggers', confTurno, confTamanho, confIntervalo, webhook);
        document.getElementById('statusEnvioTexto').innerHTML = '✅ <span style="color: green">Robô Ativado!</span>';
        
        isActive = true;
        document.getElementById('timerPanel').style.display = 'flex';
        postsLeft = 0; 
        nextLoteTimestamp = calcularProximoTurnoBg();
        if(simulationInterval) clearInterval(simulationInterval);
        simulationInterval = setInterval(updateTimers, 1000);
        
      } catch (e) {
        document.getElementById('statusEnvioTexto').innerText = '❌ Erro ao ativar o robô. Tente novamente.';
        document.getElementById('startBtn').disabled = false;
        document.getElementById('cancelBtn').disabled = true;
      }
    }

    async function cancelarEnvio() {
      document.getElementById('startBtn').disabled = false;
      document.getElementById('cancelBtn').disabled = true;
      document.getElementById('statusEnvioTexto').innerText = '🛑 Desligando robô...';

      try {
        await runGoogleScript('pararTriggers');
        document.getElementById('statusEnvioTexto').innerText = '🛑 Estratégia pausada.';
        
        isActive = false;
        if(simulationInterval) clearInterval(simulationInterval);
        document.getElementById('timerPanel').style.display = 'none';
        
      } catch (e) {
        document.getElementById('statusEnvioTexto').innerText = '❌ Erro ao parar. Tente novamente.';
        document.getElementById('startBtn').disabled = true;
        document.getElementById('cancelBtn').disabled = false;
      }
    }
  </script>
</body>
</html>