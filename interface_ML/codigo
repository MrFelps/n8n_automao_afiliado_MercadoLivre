// CONFIGURAÇÕES (PREENCHA COM SEUS DADOS)
const MEU_CHAT_ID = "0000000000"; // Substitua pelo seu Chat ID do Telegram
const SPREADSHEET_ID = "00000000000000000000000000000000000000000000"; // Substitua pelo ID da sua Planilha do Google
const NOME_ABA = "Página1"; // Nome da aba onde os links vão ficar
// ==========================================

function doGet() {
  return HtmlService.createHtmlOutputFromFile('Index')
      .setTitle('Painel Lotes - ML')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function adicionarLinksPlanilha(urls) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(NOME_ABA);
  const dados = urls.map(url => [url]); 
  sheet.getRange(sheet.getLastRow() + 1, 1, dados.length, 1).setValues(dados);
  return true;
}

function carregarPendentesPlanilha() {
  const prop = PropertiesService.getScriptProperties();
  let linhaAtual = parseInt(prop.getProperty('PONTEIRO_LEITURA')) || 1; 
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(NOME_ABA);
  const ultimaLinha = sheet.getLastRow();
  
  if (linhaAtual > ultimaLinha) return []; 
  
  const numLinhas = ultimaLinha - linhaAtual + 1;
  const dados = sheet.getRange(linhaAtual, 1, numLinhas, 1).getValues();
  return dados.map(row => row[0]).filter(url => url !== ""); 
}

